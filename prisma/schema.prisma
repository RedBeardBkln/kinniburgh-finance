// Money is stored as NUMERIC(14,2) — never floats.
// All dates stored UTC. Soft-delete via archivedAt on tax-relevant records.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String
  role                String    @default("owner")
  totpSecret          String?   // encrypted; null = MFA not yet enrolled
  totpVerified        Boolean   @default(false)
  notificationPrefs   Json      @default("{}")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions              Session[]
  notificationUsers     NotificationUser[]
  pushSubscriptions     PushSubscription[]
  auditLogs             AuditLog[]
  vaultOtps             VaultOtp[]
  vaultSessions         VaultSession[]
  passwordResetTokens   PasswordResetToken[]
}

model PasswordResetToken {
  id          String    @id @default(uuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Core financial entities ─────────────────────────────────────────────────

model Entity {
  id             String    @id @default(uuid())
  name           String    @unique
  slug           String?   @unique  // URL-safe slug; null = not shown in nav
  navLabel       String?            // short label for header tabs
  hiddenInNav    Boolean   @default(false)
  dbaName        String?
  type           String    // personal | business
  foundedDate    DateTime?
  taxStatusNotes String?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts          Account[]
  transactions      Transaction[]
  budgets           Budget[]
  receipts          Receipt[]
  glCodes           GlCode[]
  documents         Document[]
  scheduledBills    ScheduledBill[]
  notifications     Notification[]
  incomeSources     IncomeSource[]
  taxWorkspaces     TaxWorkspace[]
  insurancePolicies  InsurancePolicy[]
  mileageEntries     MileageEntry[]
  taxDeadlines       TaxDeadline[]
  projects           Project[]
  recurringExpenses  RecurringExpense[]
  rentalBookings     RentalBooking[]
}

model Institution {
  id                  String    @id @default(uuid())
  name                String    @unique
  plaidInstitutionId  String?   // Plaid's institution_id, populated on first connect attempt
  plaidCoverageNotes  String?   // supported | unsupported | requires_fallback
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts  Account[]
}

model Account {
  id                 String      @id @default(uuid())
  institutionId      String
  entityId           String
  nickname           String
  mask               String?     // last 4 digits
  accountType        String      // checking | savings | credit_card | mortgage | loan | investment | insurance
  minimumBalance     Decimal?    @db.Decimal(14, 2)
  minimumBalanceFee  Decimal?    @db.Decimal(14, 2)
  integrationMode    String      @default("manual_entry") // plaid | manual_import | manual_entry
  currency           String      @default("USD")
  plaidItemId        String?     // references PlaidItem.itemId
  plaidAccountId     String?     // Plaid's per-account account_id
  currentBalance     Decimal?    @db.Decimal(14, 2) // manually set or Plaid-synced
  currentBalanceAt   DateTime?                       // when currentBalance was last set
  archivedAt         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  institution              Institution        @relation(fields: [institutionId], references: [id])
  entity                   Entity             @relation(fields: [entityId], references: [id])
  plaidItem                PlaidItem?         @relation(fields: [plaidItemId], references: [itemId])
  transactions             Transaction[]
  budgets                  Budget[]
  scheduledTransfersFrom   ScheduledTransfer[] @relation("FromAccount")
  scheduledTransfersTo     ScheduledTransfer[] @relation("ToAccount")
  scheduledBills           ScheduledBill[]
  accrualEnvelopes         AccrualEnvelope[]
  tagRules                 TagRule[]
  incomeSources            IncomeSource[]
  projects                 Project[]
  receipts                 Receipt[]
  debtDetail               DebtDetail?

  @@unique([entityId, nickname])
}

// ─── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id                 String    @id @default(uuid())
  accountId          String
  entityId           String
  postedAt           DateTime
  amount             Decimal   @db.Decimal(14, 2) // negative = outflow
  payeeRaw           String?
  payeeNormalized    String?
  description        String?
  source             String    // plaid | import | manual | receipt
  plaidTransactionId String?   @unique
  pending            Boolean   @default(false)
  transferPairId     String?   // links the two legs of an internal transfer
  receiptId          String?
  glCodeId           String?
  projectId          String?   // optional assignment to a Project
  archivedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  account     Account          @relation(fields: [accountId], references: [id])
  entity      Entity           @relation(fields: [entityId], references: [id])
  tags        TransactionTag[]
  receipt     Receipt?         @relation(fields: [receiptId], references: [id])
  glCode      GlCode?          @relation(fields: [glCodeId], references: [id])
  project     Project?         @relation(fields: [projectId], references: [id])
  auditLogs   AuditLog[]
}

// ─── Tags ─────────────────────────────────────────────────────────────────────

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique // full path: "Food & Drink / Groceries"
  shortName String    // leaf segment only
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  parent             Tag?              @relation("TagHierarchy", fields: [parentId], references: [id])
  children           Tag[]             @relation("TagHierarchy")
  transactions       TransactionTag[]
  budgets            Budget[]
  tagRules           TagRule[]
  recurringExpenses  RecurringExpense[]
  debtDetails        DebtDetail[]
}

model TransactionTag {
  id            String      @id @default(uuid())
  transactionId String
  tagId         String
  createdAt     DateTime    @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id])

  @@unique([transactionId, tagId])
}

// ─── Budgets ──────────────────────────────────────────────────────────────────

model Budget {
  id              String   @id @default(uuid())
  tagId           String
  entityId        String
  accountId       String
  period          String   // YYYY-MM
  budgeted              Decimal  @db.Decimal(14, 2)
  additionalAmountCents Decimal  @default(0) @db.Decimal(14, 2)
  payDay                Int?     // day of month (1–31) when this bill is paid
  rolloverEnabled       Boolean  @default(false)
  rolloverAmount        Decimal? @db.Decimal(14, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tag     Tag     @relation(fields: [tagId], references: [id])
  entity  Entity  @relation(fields: [entityId], references: [id])
  account Account @relation(fields: [accountId], references: [id])

  @@unique([tagId, entityId, period])
}

// ─── Envelope automation ──────────────────────────────────────────────────────

model ScheduledTransfer {
  id            String   @id @default(uuid())
  fromAccountId String
  toAccountId   String
  amount        Decimal  @db.Decimal(14, 2)
  cadence       String   // weekly | semi_monthly | monthly
  dayRules      Json     // e.g. {"dayOfWeek": 1} or {"daysOfMonth": [1, 15]}
  purpose       String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  fromAccount Account @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount   Account @relation("ToAccount", fields: [toAccountId], references: [id])
}

model ScheduledBill {
  id              String   @id @default(uuid())
  accountId       String
  entityId        String
  payee           String
  amountType      String   // static | fluctuating | accrued
  expectedAmount  Decimal? @db.Decimal(14, 2)
  autopayDay      Int?     // day of month
  annualBudget    Decimal? @db.Decimal(14, 2)
  active          Boolean  @default(true)
  budgetTagId     String?  // Tag.id — set when auto-created from a budget line
  budgetEntityId  String?  // Entity.id — mirrors entityId for compound upsert key
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])
  entity  Entity  @relation(fields: [entityId], references: [id])

  @@unique([budgetTagId, budgetEntityId])
}

// ─── Recurring expenses (forecast + budget planning) ─────────────────────────

model RecurringExpense {
  id          String    @id @default(uuid())
  entityId    String
  name        String
  amountCents Int       // actual amount per occurrence
  frequency   String    // monthly | weekly | biweekly | quarterly | annually
  dueDay      Int?      // day of month (1–31) for monthly expenses
  nextDueDate DateTime? // next occurrence date (optional)
  tagId       String?   // linked budget category (Tag)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entity Entity @relation(fields: [entityId], references: [id])
  tag    Tag?   @relation(fields: [tagId], references: [id])
}

// ─── Rental bookings (Airbnb CSV import for forecast) ────────────────────────

model RentalBooking {
  id               String   @id @default(uuid())
  entityId         String
  confirmationCode String
  payoutDate       DateTime
  startDate        DateTime
  endDate          DateTime
  nights           Int
  guest            String
  listing          String
  grossEarnings    Decimal  @db.Decimal(10, 2)
  currency         String   @default("USD")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, confirmationCode])
}

model AccrualEnvelope {
  id                 String   @id @default(uuid())
  accountId          String
  name               String
  targetAnnualAmount Decimal  @db.Decimal(14, 2)
  fundingTransferId  String?
  currentBalance     Decimal  @db.Decimal(14, 2) @default(0)
  expectedDrawMonths Json     // [10, 11, 12, 1, 2, 3] = Oct–Mar for oil
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])
}

// ─── Receipts ─────────────────────────────────────────────────────────────────

model Receipt {
  id            String    @id @default(uuid())
  uploadedBy    String    // user id
  fileKey       String    // object storage key (encrypted at rest)
  capturedAt    DateTime
  ocrStatus     String    @default("pending") // pending | complete | failed
  vendor        String?
  receiptDate   DateTime?
  total         Decimal?  @db.Decimal(14, 2)
  description   String?
  memo          String?   // user-entered note
  glCode        String?   // freeform GL account / bookkeeping category
  taxCategory   String?   // IRS expense category for tax purposes
  ocrRaw        Json?     // raw Claude extraction response
  confirmedAt   DateTime?
  confirmedById String?   // user id (plain string, same pattern as uploadedBy)
  entityId      String
  accountId     String?   // bank account this receipt came from
  projectId     String?   // optional assignment to a Project
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  entity       Entity        @relation(fields: [entityId], references: [id])
  account      Account?      @relation(fields: [accountId], references: [id])
  project      Project?      @relation(fields: [projectId], references: [id])
  transactions Transaction[]
}

// ─── GL codes (chart of accounts, imported from QB/CPA in Phase 5) ────────────

model GlCode {
  id        String   @id @default(uuid())
  entityId  String
  code      String
  name      String
  type      String   // asset | liability | equity | revenue | expense
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entity       Entity        @relation(fields: [entityId], references: [id])
  transactions Transaction[]

  @@unique([entityId, code])
}

// ─── Documents (tax vault + document intelligence) ───────────────────────────

// Tax-related records are NEVER hard-deleted; archivedAt only.
model Document {
  id                String    @id @default(uuid())
  entityId          String
  taxYear           Int?
  docType           String    // w2 | 1099 | k1 | extension | property_tax | mortgage_interest | policy | statement | bank_statement | mortgage_statement | insurance_policy | utility_bill | other
  fileKey           String    // object storage key (encrypted)
  metadata          Json?
  notes             String?
  extractionStatus  String?   // pending | processing | complete | failed | skipped
  extractionData    Json?     // structured output from Claude extraction
  extractionModel   String?
  extractedAt       DateTime?
  archivedAt        DateTime? // archive only; hard delete is forbidden
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  entity          Entity           @relation(fields: [entityId], references: [id])
  insurancePolicy InsurancePolicy?
  solarEntries    SolarEntry[]
}

// ─── Insurance policies ───────────────────────────────────────────────────────

model InsurancePolicy {
  id                  String    @id @default(uuid())
  entityId            String
  documentId          String?   @unique // linked source Document (NWM policy upload)
  policyType          String    // term | whole | ul | property | auto | motorcycle | other
  insurer             String
  policyNumber        String?
  faceAmountCents     Int?      // cents — never float
  monthlyPremiumCents Int?      // cents ($755/mo for NWM = 75500)
  effectiveDate       DateTime?
  expiryDate          DateTime?
  notes               String?
  archivedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  entity           Entity            @relation(fields: [entityId], references: [id])
  document         Document?         @relation(fields: [documentId], references: [id])
  cashValueEntries PolicyCashValue[]
}

model PolicyCashValue {
  id             String          @id @default(uuid())
  policyId       String
  asOf           DateTime
  cashValueCents Int             // cents
  notes          String?
  createdAt      DateTime        @default(now())

  policy InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
}

// ─── Solar ROI tracker ────────────────────────────────────────────────────────

model SolarEntry {
  id              String   @id @default(uuid())
  period          String   // YYYY-MM
  billAmountCents Int      // cents
  usageKwh        Decimal? @db.Decimal(10, 2)
  gridCreditCents Int?     // cents
  documentId      String?  // linked utility_bill Document
  createdAt       DateTime @default(now())

  document Document? @relation(fields: [documentId], references: [id])
}

// ─── Monthly household review ─────────────────────────────────────────────────

model MonthlyReview {
  id        String   @id @default(uuid())
  period    String   @unique // YYYY-MM
  data      Json     // full summary: spend, budget health, upcoming, account snapshot
  createdAt DateTime @default(now())
}

// ─── Tax workspaces ───────────────────────────────────────────────────────────

// Tax-related records are NEVER hard-deleted.
model TaxWorkspace {
  id        String    @id @default(uuid())
  entityId  String
  taxYear   Int
  status    String    @default("in_progress") // in_progress | extended | filed
  deadline  DateTime?
  filedAt   DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  entity         Entity             @relation(fields: [entityId], references: [id])
  checklistItems TaxChecklistItem[]

  @@unique([entityId, taxYear])
}

model TaxChecklistItem {
  id          String    @id @default(uuid())
  workspaceId String
  label       String
  completed   Boolean   @default(false)
  completedAt DateTime?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace TaxWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── Projects (cross-entity expense tracker with master budget) ───────────────

model Project {
  id          String    @id @default(uuid())
  entityId    String?   // master entity (Personal, EK Consulting, etc.) — null = no entity assigned yet
  accountId   String?   // optional link to Slush Funds (x3612) account
  name        String
  description String?
  budget      Decimal   @db.Decimal(14, 2) // master budget; spend tracked from transactions + receipts
  targetDate  DateTime?
  status      String    @default("active") // active | completed | paused
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entity       Entity?       @relation(fields: [entityId], references: [id])
  account      Account?      @relation(fields: [accountId], references: [id])
  transactions Transaction[]
  receipts     Receipt[]
}

// ─── Manual assets (property, vehicle — user-entered values only) ──────────────

model ManualAsset {
  id         String    @id @default(uuid())
  name       String    // "Sudden Valley property", "Toyota Tacoma 1999"
  category   String    // real_estate | vehicle | other
  valueCents Int       // cents — never float; user-entered or approved estimates only
  asOf       DateTime  // date of estimate
  notes      String?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ─── Net worth snapshots ───────────────────────────────────────────────────────

model NetWorthSnapshot {
  id                    String   @id @default(uuid())
  date                  DateTime @unique
  totalAssetsCents      Int
  totalLiabilitiesCents Int
  netWorthCents         Int
  data                  Json     // { accounts[], manualAssets[], cashValues[], liabilities[] }
  createdAt             DateTime @default(now())
}

// ─── Tag rules (payee → tag learning) ────────────────────────────────────────

model TagRule {
  id             String   @id @default(uuid())
  payeePattern   String?  // normalized payee matcher (exact or prefix)
  amountMin      Decimal? @db.Decimal(14, 2)
  amountMax      Decimal? @db.Decimal(14, 2)
  accountId      String?
  tagId          String
  confidence     Float    @default(1.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tag     Tag      @relation(fields: [tagId], references: [id])
  account Account? @relation(fields: [accountId], references: [id])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(uuid())
  entityId  String?
  type      String    // overspend | low_balance | accrual_shortfall | bill_due | anomaly
  payload   Json
  sentAt    DateTime?
  channel   String    // push | email | in_app
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  entity Entity?            @relation(fields: [entityId], references: [id])
  users  NotificationUser[]
}

model NotificationUser {
  id             String       @id @default(uuid())
  notificationId String
  userId         String
  readAt         DateTime?

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([notificationId, userId])
}

// ─── Push subscriptions (Web Push / VAPID) ───────────────────────────────────

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Audit log ────────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(uuid())
  transactionId String?
  changedBy     String   // user id
  changeType    String   // entity_change | tag_change | category_change
  before        Json?
  after         Json?
  createdAt     DateTime @default(now())

  transaction Transaction? @relation(fields: [transactionId], references: [id])
  user        User         @relation(fields: [changedBy], references: [id])
}

// ─── Income sources (for cash-flow forecast) ─────────────────────────────────

model IncomeSource {
  id          String   @id @default(uuid())
  entityId    String
  accountId   String   // deposits arrive in this account
  description String   // e.g. "Eric payroll", "Eva paycheck"
  cadence     String   // semi_monthly | biweekly | monthly | weekly
  dayRules    Json     // semi_monthly: {"daysOfMonth":[15,30]}
                       // biweekly: {"intervalDays":14,"anchorDate":"2026-01-03"}
  amount      Decimal  @db.Decimal(14, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entity  Entity  @relation(fields: [entityId], references: [id])
  account Account @relation(fields: [accountId], references: [id])
}

// ─── Plaid items (one per institution login) ──────────────────────────────────

model PlaidItem {
  id                   String    @id @default(uuid())
  itemId               String    @unique // Plaid's item_id
  accessTokenEncrypted String            // AES-256-GCM encrypted access token
  institutionId        String?           // Plaid institution_id
  institutionName      String?
  status               String    @default("active") // active | requires_login | error
  lastSyncedAt         DateTime?
  cursorEncrypted      String?           // encrypted transactions/sync cursor
  consentExpiresAt     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts Account[]
}

// ─── Mileage log (business deduction tracking) ───────────────────────────────

model MileageEntry {
  id          String    @id @default(uuid())
  entityId    String
  date        DateTime
  miles       Int                            // whole miles per trip
  purpose     String                         // "Client meeting — Hartford"
  billable    Boolean   @default(false)
  ratePerMile Decimal   @db.Decimal(5, 3) @default(0.700) // IRS rate at time of entry
  notes       String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entity Entity @relation(fields: [entityId], references: [id])
}

// ─── Tax deadlines (quarterly estimates + annual filings) ─────────────────────



// Tax-related records are NEVER hard-deleted; archivedAt only.
model TaxDeadline {
  id         String    @id @default(uuid())
  entityId   String
  label      String                         // "2025 Schedule C — extended"
  dueDate    DateTime
  type       String                         // quarterly_est | annual | extension | other
  status     String    @default("upcoming") // upcoming | filed | waived
  notes      String?
  archivedAt DateTime?                      // never hard-delete tax records
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  entity Entity @relation(fields: [entityId], references: [id])
}

// ─── Secure vault (financial credentials + contacts) ─────────────────────────

model VaultEntry {
  id            String   @id @default(uuid())
  name          String
  category      String   // "login" | "account" | "contact" | "card" | "other"
  institution   String?
  dataEncrypted String   // encrypt(JSON.stringify({ fields: [{key,value}] }))
  notes         String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VaultOtp {
  id        String    @id @default(uuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VaultSession {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Financial goals (advisor) ───────────────────────────────────────────────

model FinancialGoal {
  id                 String    @id @default(uuid())
  title              String
  description        String?
  category           String    // emergency_fund | debt_payoff | savings | investment | income | lifestyle | other
  targetAmountCents  Int?      // null = qualitative goal
  currentAmountCents Int?      // manually tracked progress
  targetDate         DateTime?
  priority           Int       @default(1) // 1=high, 2=medium, 3=low
  status             String    @default("active") // active | achieved | paused
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// ─── Debt tracking ────────────────────────────────────────────────────────────

model DebtDetail {
  id                   String   @id @default(cuid())
  accountId            String?  @unique        // null = standalone debt
  name                 String
  originalBalanceCents Int?                    // for progress bar
  manualBalanceCents   Int?                    // balance when no Plaid sync
  interestRate         Decimal? @db.Decimal(5, 3)
  monthlyPaymentCents  Int?
  paymentDay           Int?                    // day of month (1–31)
  tagId                String?
  notes                String?
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  tag     Tag?     @relation(fields: [tagId], references: [id], onDelete: SetNull)
}

// ─── App settings ─────────────────────────────────────────────────────────────

model AppSetting {
  key   String @id
  value String
}
